{
  "name": "@brashkie/media-core",
  "version": "0.1.5",
  "description": "[DEPRECATED] Migrated to @kryxjs/core. Run: npm install @kryxjs/core. See https://github.com/Brashkie/kryx-core",
  "type": "commonjs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "preartifacts": "node scripts/create-npm-dirs.js",
    "artifacts": "napi artifacts",
    "build:native": "napi build --platform --release --cargo-cwd crates/mc-node --js index.js --dts index.d.ts",
    "build:native:debug": "napi build --platform --cargo-cwd crates/mc-node --js index.js --dts index.d.ts",
    "build:ts": "tsup && node scripts/fix-dts.js",
    "build": "npm run build:native && npm run build:ts",
    "build:debug": "npm run build:native:debug && npm run build:ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:rust && npm run test:vitest && npm run test:dual",
    "test:vitest": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run",
    "test:watch": "cross-env VITE_CJS_IGNORE_WARNING=true vitest",
    "test:rust": "cross-env CARGO_INCREMENTAL=0 cargo test --workspace --exclude mc-node",
    "test:dual": "node __tests__/cjs.test.cjs && node __tests__/esm.test.mjs",
    "test:coverage": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --coverage",
    "test:coverage:ui": "cross-env VITE_CJS_IGNORE_WARNING=true vitest --coverage --ui",
    "coverage:open": "node -e \"require('child_process').exec(process.platform==='win32'?'start coverage/index.html':process.platform==='darwin'?'open coverage/index.html':'xdg-open coverage/index.html')\"",
    "example:cjs": "node examples/cjs-example.cjs",
    "example:esm": "node examples/esm-example.mjs",
    "example:ts": "tsx examples/ts-example.ts",
    "examples": "npm run example:cjs && npm run example:esm && npm run example:ts",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"__tests__/**/*.ts\"",
    "format:rust": "cargo fmt --all",
    "clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "clean": "node -e \"const fs=require('fs');['dist','target','index.js','index.d.ts','npm'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));fs.readdirSync('.').filter(f=>f.endsWith('.node')).forEach(f=>fs.rmSync(f,{force:true}));console.log('✓ Cleaned')\"",
    "version": "napi version"
  },
  "files": [
    "dist/",
    "index.js",
    "index.d.ts",
    "media/",
    "README.md",
    "README.es.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "deprecated",
    "moved",
    "kryxjs",
    "multimedia",
    "media",
    "video",
    "audio",
    "pipeline",
    "kryx",
    "ffmpeg",
    "rust",
    "napi",
    "native",
    "esm",
    "commonjs",
    "dual-package"
  ],
  "author": "Brashkie",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brashkie/media-core.git"
  },
  "bugs": {
    "url": "https://github.com/Brashkie/kryx-core/issues"
  },
  "homepage": "https://github.com/Brashkie/kryx-core#readme",
  "engines": {
    "node": ">= 18"
  },
  "napi": {
    "name": "media-core",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "optionalDependencies": {
    "@brashkie/media-core-win32-x64-msvc": "0.1.5",
    "@brashkie/media-core-win32-arm64-msvc": "0.1.5",
    "@brashkie/media-core-darwin-x64": "0.1.5",
    "@brashkie/media-core-darwin-arm64": "0.1.5",
    "@brashkie/media-core-linux-x64-gnu": "0.1.5",
    "@brashkie/media-core-linux-x64-musl": "0.1.5",
    "@brashkie/media-core-linux-arm64-gnu": "0.1.5"
  },
  "devDependencies": {
    "@napi-rs/cli": "2.18.4",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^1.2.0"
  }
}