# ═════════════════════════════════════════════════════════════════════════════
# @brashkie/media-core — .gitignore
# ═════════════════════════════════════════════════════════════════════════════

# ─── Build artifacts ─────────────────────────────────────────────────────────
/target
/dist
/coverage
.tsbuildinfo
*.tsbuildinfo

# Native binaries — never commit compiled .node files
*.node

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
/.pnp.js
.yarn/install-state.gz
/.pnpm-store

# ─── Per-platform npm packages (regenerated by scripts/create-npm-dirs.js) ──
/npm

# ─── Lock files (decide your policy here) ────────────────────────────────────
# We commit package-lock.json for reproducible installs.
# Uncomment to ignore:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Environment / secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.swn
*~

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Rust ────────────────────────────────────────────────────────────────────
**/*.rs.bk
*.pdb
Cargo.lock.bak

# ─── Profiling output ────────────────────────────────────────────────────────
*.profraw
*.profdata
flamegraph.svg
perf.data*
callgrind.out.*

# ─── Test output ─────────────────────────────────────────────────────────────
/lcov.info
/coverage.xml
/junit.xml
/.nyc_output

# ─── Local notes / scratch (never commit) ────────────────────────────────────
/.scratch
/TODO.local.md
/NOTES.local.md
*.local.md
*.local.txt

# ─── NOT ignored — explicit allow list ──────────────────────────────────────
# Placeholder index.js / index.d.ts ARE tracked.
# They're overwritten by `napi build` but committed so that:
#   - `tsc --noEmit` works before the first native build
#   - IDE language servers don't show errors on a fresh clone
# The media/ folder (logo, etc.) IS tracked — that's intentional.
.npmrc