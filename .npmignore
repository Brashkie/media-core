# ─── Source code (we ship dist/, not src/) ───────────────────────
src/
crates/
__tests__/
examples/
scripts/
docs/
benches/

# ─── Build artifacts that shouldn't ship ─────────────────────────
target/
coverage/
node_modules/
*.tsbuildinfo
.tsbuildinfo

# ─── Per-platform npm folder (each platform pkg published separately) ─
npm/

# ─── Tooling configs (irrelevant to consumers) ───────────────────
.github/
.vscode/
.idea/
.editorconfig
.eslintrc*
.prettierrc*
.gitignore
.gitattributes
tsup.config.ts
vitest.config.ts
tsconfig.json
Cargo.toml
Cargo.lock
rust-toolchain.toml
build.rs

# ─── Editor / OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Test / coverage output ──────────────────────────────────────
*.log
lcov.info
coverage.xml
junit.xml
.nyc_output

# ─── Local notes ─────────────────────────────────────────────────
.scratch/
TODO.local.md
NOTES.local.md
*.local.md

# ─── Internal docs that don't help consumers ─────────────────────
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
docs/ARCHITECTURE.md
docs/ROADMAP.md

# ─── Source maps (optional — comment out to include) ─────────────
# dist/*.map
